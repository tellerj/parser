#!/usr/bin/env bash
# Pre-commit hook: run tests and enforce zero pyright errors.

set -euo pipefail

# Ensure ~/.local/bin is on PATH (pip user installs).
export PATH="$HOME/.local/bin:$PATH"

# Run from the repo root so config files are found.
cd "$(git rev-parse --show-toplevel)"

# --- Tests ---
echo "pre-commit: running tests..."
if ! python3 -m pytest tests/ -q --tb=short 2>&1; then
    echo ""
    echo "pre-commit: tests failed. Fix them before committing."
    exit 1
fi

# --- Type checking ---
PYRIGHT="$(command -v pyright 2>/dev/null || true)"
if [ -z "$PYRIGHT" ]; then
    for candidate in "$HOME/.local/bin/pyright" .venv/bin/pyright; do
        if [ -x "$candidate" ]; then
            PYRIGHT="$candidate"
            break
        fi
    done
fi

if [ -z "$PYRIGHT" ]; then
    echo "pre-commit: pyright not found — skipping type check."
    echo "  Install with: pip install pyright"
    exit 0
fi

echo "pre-commit: running pyright..."
if ! "$PYRIGHT" 2>&1; then
    echo ""
    echo "pre-commit: pyright found errors or warnings. Fix them before committing."
    exit 1
fi
